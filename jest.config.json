{
  "transform": {},
  "testEnvironment": "node",
  "moduleFileExtensions": ["js", "json"],
  "testMatch": ["**/*.test.js"],
  "collectCoverageFrom": [
    "src/utils/designations/**/*.js",
    "src/utils/designator.js",
    "src/utils/trips.js"
  ],
  "coverageDirectory": "coverage",
  "coverageReporters": ["text", "text-summary", "lcov"],
  "coverageThreshold": {
    "global": {
      "branches": 65,
      "functions": 80,
      "lines": 80,
      "statements": 80
    }
  }
}
